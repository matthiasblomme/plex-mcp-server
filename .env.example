PLEX_URL=https://app.plex.tv
PLEX_TOKEN=TOKEN

# Optional: Trakt Integration for hybrid recommendations
# Get your API key at https://trakt.tv/oauth/applications
# TRAKT_CLIENT_ID=your_trakt_client_id_here

# Optional: OAuth 2.1 / OIDC Configuration for Remote MCP
# Uncomment and configure these to enable OAuth authentication
# MCP_OAUTH_ENABLED=true
# MCP_OAUTH_ISSUER=https://authentik.example.com/application/o/plex-mcp/
# MCP_SERVER_URL=https://mcp.example.com
# MCP_OAUTH_JWKS_CACHE_TTL=3600
